{
  "name": "extension-dlp",
  "version": "1.0.0",
  "description": "Browser DLP extension - block upload/download of dangerous files and domains",
  "scripts": {
    "build:chrome": "webpack --env browser=chrome",
    "build:firefox": "webpack --env browser=firefox",
    "build:chrome:offline": "webpack --env browser=chrome --env localModel=true",
    "build:firefox:offline": "webpack --env browser=firefox --env localModel=true",
    "build": "npm run build:chrome && npm run build:firefox",
    "download-model": "node scripts/download-model.js",
    "release": "node scripts/build-release.js",
    "release:chrome": "node scripts/build-release.js chrome",
    "release:firefox": "node scripts/build-release.js firefox",
    "watch:chrome": "webpack --env browser=chrome --watch",
    "test": "jest"
  },
  "dependencies": {
    "magika": "^1.0.0",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "babel-jest": "^29.7.0",
    "babel-loader": "^9.1.3",
    "copy-webpack-plugin": "^12.0.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  }
}
